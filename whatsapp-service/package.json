{
    "name": "whatsapp-service",
    "version": "1.0.0",
    "description": "CRM WhatsApp multi-session service",
    "main": "dist/index.js",
    "scripts": {
        "postinstall": "prisma generate --schema=prisma/schema.prisma || true",
        "build": "prisma generate --schema=prisma/schema.prisma && tsc",
        "start": "node dist/index.js",
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts"
    },
    "dependencies": {
        "@hapi/boom": "^10.0.1",
        "@prisma/client": "^6.0.0",
        "@whiskeysockets/baileys": "^6.17.16",
        "cors": "^2.8.6",
        "dotenv": "^16.6.1",
        "express": "^4.22.1",
        "pino": "^8.21.0",
        "pino-pretty": "^10.3.1",
        "qrcode": "^1.5.4"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.25",
        "@types/hapi__boom": "^7.4.1",
        "@types/node": "^20.19.33",
        "@types/qrcode": "^1.5.6",
        "prisma": "^6.0.0",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.2"
    }
}
