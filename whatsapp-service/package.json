{
    "name": "whatsapp-service",
    "version": "1.0.0",
    "description": "CRM WhatsApp multi-session service",
    "main": "dist/index.js",
    "scripts": {
        "postinstall": "prisma generate --schema=prisma/schema.prisma || true",
        "build": "prisma generate --schema=prisma/schema.prisma && tsc",
        "start": "node dist/index.js",
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts"
    },
    "dependencies": {
        "@whiskeysockets/baileys": "^6.7.18",
        "@prisma/client": "^6.0.0",
        "@hapi/boom": "^10.0.1",
        "express": "^4.18.2",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "qrcode": "^1.5.3",
        "pino": "^8.17.2",
        "pino-pretty": "^10.3.1"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/cors": "^2.8.17",
        "@types/qrcode": "^1.5.5",
        "@types/node": "^20.10.0",
        "typescript": "^5.3.2",
        "ts-node-dev": "^2.0.0",
        "prisma": "^6.0.0"
    }
}