{
  "name": "crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build --no-lint",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "tenant:create": "ts-node scripts/tenant_create.ts",
    "test:tenant-scope": "node scripts/test_tenant_scope.js",
    "backup": "node scripts/backup-database.js",
    "backup:local": "BACKUP_DIR=./local-backups node scripts/backup-database.js",
    "backup:mac": "./scripts/mac-daily-backup.sh",
    "backup:setup-cron": "./scripts/setup-mac-cron.sh",
    "backup:setup-launchagent": "./scripts/setup-mac-launchagent.sh",
    "desktop": "electron .",
    "desktop:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:3000 && ELECTRON_START_URL=http://localhost:3000/admin electron .\"",
    "desktop:dist": "npm run build && electron-builder",
    "desktop:dist:mac": "npm run build && electron-builder --mac dmg zip",
    "desktop:dist:win": "npm run build && electron-builder --win nsis portable"
  },
  "main": "desktop/main.js",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^1.16.10",
    "@prisma/client": "^6.16.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@swc/helpers": "0.5.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "autoprefixer": "^10.4.21",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "critters": "^0.0.23",
    "date-fns": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.479.0",
    "moment": "^2.30.1",
    "next": "14.1.0",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.6",
    "react": "18.2.0",
    "react-day-picker": "^9.5.1",
    "react-dom": "18.2.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^3.4.18"
  },
  "devDependencies": {
    "@types/node": "20.11.20",
    "@types/react": "18.2.58",
    "@types/react-dom": "18.2.19",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "8.56.0",
    "eslint-config-next": "14.1.0",
    "prisma": "^6.16.2",
    "ts-node": "^10.9.2",
    "typescript": "5.3.3",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.proacente.crm",
    "productName": "Pro Acente CRM",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "desktop/**/*",
      ".next/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json",
      "next.config.js",
      "middleware.ts",
      "prisma/**/*"
    ],
    "extraMetadata": {
      "main": "desktop/main.js"
    },
    "mac": {
      "category": "public.app-category.business",
      "icon": "public/crmlogo/proAcentelogo-symbol.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "public/crmlogo/proAcentelogo-symbol.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
